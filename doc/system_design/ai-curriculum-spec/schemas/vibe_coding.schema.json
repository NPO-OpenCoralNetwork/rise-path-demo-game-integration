{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "vibe-coding.schema.json",
  "title": "VibeCodingCurriculum",
  "type": "object",
  "additionalProperties": false,
  "required": ["ui_template_id", "modules"],
  "properties": {
    "curriculum_id": { "type": "string", "minLength": 1 },
    "version": { "type": "integer", "minimum": 1 },
    "ui_template_id": { "const": "vibe_coding" },
    "title": { "$ref": "#/$defs/localizedText" },
    "description": { "$ref": "#/$defs/localizedText" },
    "content_mix": { "$ref": "#/$defs/mix" },
    "assessment_mix": { "$ref": "#/$defs/mix" },
    "modules": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/module" }
    }
  },
  "$defs": {
    "localizedText": {
      "type": "object",
      "additionalProperties": false,
      "required": ["en", "jp"],
      "properties": {
        "en": { "type": "string", "minLength": 1 },
        "jp": { "type": "string", "minLength": 1 }
      }
    },
    "mix": {
      "type": "object",
      "additionalProperties": { "type": "number", "minimum": 0, "maximum": 1 }
    },
    "module": {
      "type": "object",
      "additionalProperties": false,
      "required": ["module_id", "title", "lessons"],
      "properties": {
        "module_id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "objective": { "type": "string" },
        "prereq_modules": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "estimated_hours": { "type": "number", "minimum": 0 },
        "deliverable": { "type": "string" },
        "assessment": { "type": "string" },
        "module_ui_hints": { "$ref": "#/$defs/moduleUiHints" },
        "lessons": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/lesson" }
        }
      }
    },
    "moduleUiHints": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "card_title": { "type": "string" },
        "card_text": { "type": "string" },
        "tags": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "difficulty": { "type": "string" }
      }
    },
    "lesson": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lesson_id", "summary", "estimated_min", "unlock_rule", "retry_policy", "ui_hints"],
      "properties": {
        "lesson_id": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1 },
        "estimated_min": { "type": "number", "minimum": 1 },
        "unlock_rule": {
          "type": "string",
          "enum": ["doc_completed", "manual", "immediate"]
        },
        "retry_policy": { "type": "string", "minLength": 1 },
        "doc_blocks": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/docBlock" }
        },
        "exercises": {
          "type": "array",
          "items": { "$ref": "#/$defs/exercise" }
        },
        "quiz": {
          "type": "array",
          "items": { "$ref": "#/$defs/quiz" }
        },
        "rubric": { "$ref": "#/$defs/rubric" },
        "resources": {
          "type": "array",
          "items": { "$ref": "#/$defs/resource" }
        },
        "citations": {
          "type": "array",
          "items": { "$ref": "#/$defs/citation" }
        },
        "ui_hints": { "$ref": "#/$defs/lessonUiHints" }
      }
    },
    "lessonUiHints": {
      "type": "object",
      "additionalProperties": false,
      "required": ["card_title", "card_text", "cta", "difficulty", "time", "tags"],
      "properties": {
        "card_title": { "type": "string", "minLength": 1 },
        "card_text": { "type": "string", "minLength": 1 },
        "cta": { "type": "string", "minLength": 1 },
        "difficulty": { "type": "string", "minLength": 1 },
        "time": { "type": "string", "minLength": 1 },
        "tags": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "docBlock": {
      "oneOf": [
        { "$ref": "#/$defs/textBlock" },
        { "$ref": "#/$defs/bulletsBlock" },
        { "$ref": "#/$defs/codeBlock" }
      ]
    },
    "textBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "content"],
      "properties": {
        "type": { "const": "text" },
        "content": { "type": "string", "minLength": 1 }
      }
    },
    "bulletsBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "items"],
      "properties": {
        "type": { "const": "bullets" },
        "items": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "codeBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "content", "language"],
      "properties": {
        "type": { "const": "code" },
        "content": { "type": "string", "minLength": 1 },
        "language": { "type": "string", "minLength": 1 }
      }
    },
    "exercise": {
      "type": "object",
      "additionalProperties": false,
      "required": ["prompt", "expected"],
      "properties": {
        "prompt": { "type": "string", "minLength": 1 },
        "expected": { "type": "string", "minLength": 1 }
      }
    },
    "quiz": {
      "type": "object",
      "additionalProperties": false,
      "required": ["q", "choices", "answer"],
      "properties": {
        "q": { "type": "string", "minLength": 1 },
        "choices": {
          "type": "array",
          "minItems": 2,
          "items": { "type": "string", "minLength": 1 }
        },
        "answer": { "type": "integer", "minimum": 0 }
      }
    },
    "rubric": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "criteria": {
          "type": "array",
          "items": { "$ref": "#/$defs/rubricCriterion" }
        }
      }
    },
    "rubricCriterion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "weight"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "weight": { "type": "number", "minimum": 0 }
      }
    },
    "resource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "url"],
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "minLength": 1 }
      }
    },
    "citation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["material_id", "ref", "quote"],
      "properties": {
        "material_id": { "type": "string", "minLength": 1 },
        "ref": { "type": "string", "minLength": 1 },
        "quote": { "type": "string", "minLength": 1 }
      }
    }
  }
}
