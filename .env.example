# === Rise Path Environment Configuration ===

# --- Required for Production ---

# Supabase (Auth ONLY — do not use Supabase Postgres URI for app data)
# Use the same Supabase project as Nexloom if you want the same email/password.
# Setup: doc/env_local_setup_issue15.md — verify: npm run env:check -- --db --auth
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_APP_BASE_PATH=/

# Supabase Backend (JWT validation — Phase 7)
# Service Role Key recommended for server-side JWT validation.
# Falls back to VITE_SUPABASE_* if not set.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Development mode user ID (ignored in production)
PHASE1_USER_ID=00000000-0000-0000-0000-000000000001

# PostgreSQL Database
DATABASE_URL_PHASE1=postgresql://user:password@host:5432/risepath

# Gemini AI API Key (backend — legacy /ai/generate; v3 prefers Hermes)
GEMINI_API_KEY=your-gemini-api-key

# Hermes Agent API Server (Phase 16-6 — Express proxy target)
# See hermes/README.md for profile setup
HERMES_API_URL=http://127.0.0.1:8642
HERMES_API_KEY=change-me-local-dev

# --- Optional ---

# Demo mode: set to 'false' for production (uses DB for course data)
# Also enables strict auth (no guest/mock login, no server PHASE1 fallback)
# Default: true (uses bundled demo course data)
VITE_DEMO_MODE=true
# RISEPATH_STRICT_AUTH=true
# VITE_STRICT_AUTH=true

# API enabled: set to 'false' to use localStorage-only mode
# Default: true
VITE_API_ENABLED=true
VITE_API_BASE_URL=/api/v2

# Server port (default: 3006)
PORT=3006

# --- Kokoro TTS (optional — Issue #3) ---
# ONNX sidecar on risepath-vm. See doc/ai-curriculum-spec/09_content_types_tts.md
KOKORO_TTS_URL=http://127.0.0.1:8880
KOKORO_TTS_DEFAULT_VOICE_JA=jf_alpha
KOKORO_TTS_DEFAULT_VOICE_EN=af_bella

# --- Nexloom Integration (optional) ---
VITE_NEXLOOM_WORLDS_BASE_URL=
VITE_NEXLOOM_REALM_ID=
VITE_NEXLOOM_WORLDS_ORGANIZATION_ID=
VITE_NEXLOOM_WORLDS_BEARER_TOKEN=
