# Vercel → Project Settings → Environment Variables (Production)
# Copy values from Supabase dashboard + your API origin (Tailscale hostname or public API URL).

VITE_DEMO_MODE=false
VITE_API_ENABLED=true
# Tailscale hostname (browser must be on same tailnet). Relative /api/v2 needs a reverse proxy Vercel does not provide.
VITE_API_BASE_URL=http://risepath-vm:3006/api/v2
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional: subpath deploy
# VITE_APP_BASE_PATH=/