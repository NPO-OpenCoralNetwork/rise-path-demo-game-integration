# Rise Path VM stack — copy to stack.env (never commit stack.env)
# See doc/risepath_vm_deployment.md
#
# Canonical DB role: risepath_app (matches scripts/vm/postgres_risepath_bootstrap.sql)

# --- Postgres (db service) ---
POSTGRES_USER=risepath_app
POSTGRES_PASSWORD=change-me
POSTGRES_DB=risepath

# --- API (api service) ---
DATABASE_URL_PHASE1=postgresql://risepath_app:change-me@db:5432/risepath
PORT=3006
NODE_ENV=production

# Supabase Auth (JWT validation only — not Supabase Postgres)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=change-me

# --- Hermes (hermes service — compose profile `full`) ---
# Run once: scripts/init-hermes-profile.sh
# HERMES_API_KEY must equal API_SERVER_KEY (Express proxy only; never expose to browser)
HERMES_API_URL=http://hermes:8642
HERMES_API_KEY=change-me-local-dev
API_SERVER_ENABLED=true
API_SERVER_PORT=8642
API_SERVER_KEY=change-me-local-dev
OPENROUTER_API_KEY=change-me
COMPOSE_PROFILES=full
# Hermes MCP subprocess / tools also need DATABASE_URL_PHASE1 (same value as api)

# --- MCP SSE (mcp service) ---
# api + mcp + hermes share DATABASE_URL_PHASE1, SUPABASE_*, and NODE_ENV=production
MCP_SSE_PORT=3100
# Expose curriculum-builder + admin tools to Hermes (matches hermes/config.yaml allowlist)
RISE_PATH_MCP_PROFILE=admin
PHASE1_USER_ID=00000000-0000-0000-0000-000000000001
# Service-to-service auth for Hermes → MCP SSE (must match hermes config Authorization header)
RISE_PATH_BRIDGE_TOKEN=change-me-bridge-token

# --- Kokoro TTS (kokoro-tts service) ---
KOKORO_TTS_URL=http://kokoro-tts:8880
KOKORO_TTS_DEFAULT_VOICE_JA=jf_alpha
KOKORO_TTS_DEFAULT_VOICE_EN=af_bella

# --- Memanto learner memory (Phase 19 — compose overlay + profile memory) ---
# Enable after setting a real secret: MEMANTO_ENABLED=true and add "memory" to COMPOSE_PROFILES
# COMPOSE_PROFILES=full,memory
MEMANTO_ENABLED=false
MEMANTO_SECRET_KEY=change-me-memanto-secret
MEMANTO_API_URL=http://memanto:8000
MEMANTO_API_PORT=8100
MEMANTO_SESSION_DURATION_HOURS=24
MEMANTO_RECALL_LIMIT=8
MEMANTO_MIN_CONFIDENCE_WRITE=0.7
MOORCHEH_EMBEDDING_MODEL=nomic-embed-text
MOORCHEH_LLM_MODEL=qwen2.5:0.5b

# --- Optional legacy Gemini ---
# GEMINI_API_KEY=

# --- API image build args (docker compose build) ---
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=change-me
VITE_DEMO_MODE=false