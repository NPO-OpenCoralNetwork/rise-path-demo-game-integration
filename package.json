{
  "name": "rise-path",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node server.js & node --max-old-space-size=8192 ./node_modules/vite/bin/vite.js --port 3007",
    "build": "vite build",
    "build:prod": "VITE_DEMO_MODE=false vite build",
    "start": "NODE_ENV=production node server.js",
    "preview": "vite preview",
    "mcp": "node mcp-server/index.js",
    "mcp:sse": "node mcp-server/index.js --sse 3100",
    "db:migrate": "node scripts/db-migrate.mjs",
    "db:migrate:status": "node scripts/db-migrate.mjs --status",
    "env:check": "node scripts/verify-env.mjs",
    "smoke:prod": "node scripts/smoke-prod.mjs",
    "smoke:prod:e2e": "node scripts/smoke-prod-e2e.mjs",
    "smoke:learner-memory": "node scripts/smoke-learner-memory-e2e.mjs",
    "smoke:hermes:e2e": "node scripts/smoke-hermes-chat-e2e.mjs",
    "smoke:hermes:e2e:vm": "E2E_API_URL=http://risepath-vm:3006 node scripts/smoke-hermes-chat-e2e.mjs",
    "tunnel:memanto": "bash scripts/start-memanto-tunnel.sh",
    "prep:mcp-memory-user": "node scripts/prep-mcp-memory-test-user.mjs",
    "smoke:vm": "node scripts/smoke-vm-stack.mjs",
    "smoke:tts": "node scripts/smoke-kokoro-tts.mjs",
    "smoke:tts:api": "node scripts/smoke-kokoro-tts.mjs --api",
    "vercel:link": "vercel link --yes --project rise-path-demo-game-integration",
    "vercel:deploy": "NODE_OPTIONS=--max-old-space-size=8192 vercel deploy --archive=tgz --prod --yes",
    "env:inventory": "node scripts/verify-env-inventory.mjs",
    "test": "node --experimental-strip-types --test server/tests/*.test.js",
    "typecheck": "tsc --noEmit",
    "audit:prod": "npm audit --omit=dev"
  },
  "dependencies": {
    "@google/genai": "^1.33.0",
    "@supabase/supabase-js": "^2.89.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "express-rate-limit": "^8.4.1",
    "lucide-react": "^0.561.0",
    "mermaid": "^11.12.2",
    "multer": "^2.0.2",
    "pdf-parse": "^1.1.1",
    "pg": "^8.12.0",
    "phaser": "^3.80.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-is": "^19.2.3",
    "react-markdown": "^10.1.0",
    "react-pdf": "^10.3.0",
    "react-router-dom": "^7.12.0",
    "recharts": "^3.5.1",
    "scratch-blocks": "^1.3.0"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "playwright": "^1.61.0",
    "tailwindcss": "^4.3.1",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "~5.8.2",
    "typescript-language-server": "^5.1.3",
    "vite": "^6.2.0"
  },
  "overrides": {
    "diff": "^3.5.1",
    "form-data": "^2.5.4",
    "got": "^11.8.5",
    "http-cache-semantics": "^4.1.1",
    "minimist": "^1.2.6",
    "qs": "^6.14.1",
    "tough-cookie": "^4.1.3",
    "uuid": "^11.1.0",
    "request": "npm:@cypress/request@^3.0.8",
    "google-closure-library": "20230802.0.0",
    "scratch-l10n": "^6.1.53"
  }
}
